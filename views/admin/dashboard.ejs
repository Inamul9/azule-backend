  <!-- ══════════════════════════════════════
       SCRIPTS
  ══════════════════════════════════════ -->
  <script>
    // ─── Data ────────────────────────────────────────────────
    let allBookings = <%- JSON.stringify(bookings) %>;
    let filterStatus = 'all';

    // ─── Tab Switching ────────────────────────────────────────
    function switchTab(id) {
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
      const panel = document.getElementById('panel-' + id);
      const nav   = document.getElementById('nav-' + id);
      if (panel) panel.classList.add('active');
      if (nav)   nav.classList.add('active');
      localStorage.setItem('admin_tab', id);
    }

    window.addEventListener('DOMContentLoaded', () => {
      const saved = localStorage.getItem('admin_tab') || 'bookings';
      switchTab(saved);
    });

    // ─── Toast ────────────────────────────────────────────────
    function showToast(msg, isError = false) {
      const t = document.getElementById('toast');
      const m = document.getElementById('toast-msg');
      const i = document.getElementById('toast-icon');
      m.textContent = msg;
      i.textContent = isError ? '✕' : '✓';
      t.className = 'toast show ' + (isError ? 'toast-error' : 'toast-success');
      setTimeout(() => t.classList.remove('show'), 3600);
    }

    // ─── Loading / Success ────────────────────────────────────
    function showLoading(txt) {
      document.getElementById('loading-label').textContent = txt || 'Saving…';
      document.getElementById('loading-overlay').classList.add('active');
    }
    function hideLoading() {
      document.getElementById('loading-overlay').classList.remove('active');
    }
    function showSuccess(txt) {
      document.getElementById('success-label').textContent = txt || 'Saved!';
      const el = document.getElementById('success-overlay');
      el.classList.add('active');
      setTimeout(() => el.classList.remove('active'), 1900);
    }

    // ─── Filter / Search ──────────────────────────────────────
    function setFilter(status) {
      filterStatus = status;
      ['all','pending','confirmed','cancelled'].forEach(s => {
        const pill = document.getElementById('pill-' + s);
        if (!pill) return;
        pill.className = 'filter-pill' + (s === status ? ' active-' + s : '');
      });
      filterBookings();
    }

    function filterBookings() {
      const q = (document.getElementById('search-input').value || '').toLowerCase().trim();
      let visible = 0;
      allBookings.forEach(b => {
        const row = document.getElementById('row-' + b.id);
        if (!row) return;
        const statusOk = filterStatus === 'all' || b.status === filterStatus;
        const searchOk = !q || [b.id, b.name, b.phone, b.email, b.package, b.message || ''].some(v => v.toLowerCase().includes(q));
        if (statusOk && searchOk) { row.style.display = ''; visible++; }
        else row.style.display = 'none';
      });
      const nm = document.getElementById('no-results-msg');
      if (nm) nm.style.display = (visible === 0 && allBookings.length > 0) ? 'block' : 'none';
    }

    function updateCounters() {
      const total     = allBookings.length;
      const pending   = allBookings.filter(b => b.status === 'pending').length;
      const confirmed = allBookings.filter(b => b.status === 'confirmed').length;
      document.getElementById('stat-total').textContent     = total;
      document.getElementById('stat-pending').textContent   = pending;
      document.getElementById('stat-confirmed').textContent = confirmed;
    }

    // ─── Update Status ────────────────────────────────────────
    async function updateStatus(id, status) {
      try {
        const res = await fetch(`/admin/api/bookings/${id}/status`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status })
        });
        if (res.status === 401) { showToast('Session expired. Redirecting…', true); setTimeout(() => location.href='/admin/login', 1500); return; }
        let result;
        try { result = await res.json(); } catch(e) { showToast('Server error.', true); return; }
        if (!res.ok) { showToast(result.message || `Error ${res.status}`, true); return; }
        if (result.success) {
          const badge = document.getElementById('badge-' + id);
          if (badge) {
            badge.textContent = status;
            badge.className = 'status-badge status-' + status;
          }
          const idx = allBookings.findIndex(b => b.id === id);
          if (idx !== -1) allBookings[idx].status = status;
          updateCounters();
          filterBookings();
          showToast(`Booking ${id} → ${status}`);
        } else { showToast(result.message || 'Failed to update.', true); }
      } catch(e) { showToast('Network error — is the server running?', true); }
    }

    // ─── Delete Booking ───────────────────────────────────────
    function deleteBooking(id) {
      showConfirm('Are you sure you want to permanently delete this enquiry? This cannot be undone.', async () => {
        try {
          const res = await fetch(`/admin/api/bookings/${id}`, { method: 'DELETE' });
          if (res.status === 401) { showToast('Session expired. Redirecting…', true); setTimeout(() => location.href='/admin/login', 1500); return; }
          let result;
          try { result = await res.json(); } catch(e) { showToast('Server error.', true); return; }
          if (!res.ok) { showToast(result.message || `Error ${res.status}`, true); return; }
          if (result.success) {
            const row = document.getElementById('row-' + id);
            if (row) {
              row.style.transition = 'opacity 0.3s, transform 0.3s';
              row.style.opacity = '0';
              row.style.transform = 'translateX(-16px)';
              setTimeout(() => row.remove(), 320);
            }
            const idx = allBookings.findIndex(b => b.id === id);
            if (idx !== -1) allBookings.splice(idx, 1);
            updateCounters();
            filterBookings();
            showToast(`Booking ${id} deleted.`);
          } else { showToast(result.message || 'Failed to delete.', true); }
        } catch(e) { showToast('Network error — is the server running?', true); }
      });
    }

    // ─── Confirm Modal ────────────────────────────────────────
    function showConfirm(msg, onOk) {
      document.getElementById('confirm-msg').textContent = msg;
      document.getElementById('confirm-ok-btn').onclick = () => { closeConfirm(); if (typeof onOk === 'function') onOk(); };
      document.getElementById('confirm-overlay').classList.add('active');
    }
    function closeConfirm() {
      document.getElementById('confirm-overlay').classList.remove('active');
    }

    // ─── Enquiry Modal ────────────────────────────────────────
    function openEnquiry(b) {
      document.getElementById('enq-name').textContent = b.name;
      const colors = {
        confirmed: { bg:'rgba(13,187,149,0.12)', border:'rgba(13,187,149,0.35)', color:'#6ee7b7' },
        pending:   { bg:'rgba(234,179,8,0.12)',  border:'rgba(234,179,8,0.3)',   color:'#fde047' },
        cancelled: { bg:'rgba(239,68,68,0.12)',  border:'rgba(239,68,68,0.3)',   color:'#fca5a5' }
      };
      const c = colors[b.status] || colors.pending;
      document.getElementById('enq-status').innerHTML = `<span style="display:inline-block;padding:5px 16px;border-radius:20px;background:${c.bg};border:1px solid ${c.border};color:${c.color};font-size:10px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;font-family:'Outfit',sans-serif;margin-bottom:14px;">${b.status}</span>`;

      const d = new Date(b.timestamp);
      const ds = d.toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) + ' at ' + d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});

      const fields = [
        { k:'Enquiry ID', v: b.id, mono: true },
        { k:'Submitted', v: ds },
        { k:'Full Name', v: b.name, bold: true },
        { k:'Phone',     v: b.phone, href:`tel:${b.phone}` },
        { k:'Email',     v: b.email, href:`mailto:${b.email}` },
        { k:'Package',   v: b.package },
        { k:'Travelers', v: b.travelers + (b.travelers > 1 ? ' people' : ' person') },
        { k:'Travel Date', v: b.date || '—' },
        { k:'Message',   v: b.message || '(No message)', italic: !b.message }
      ];

      document.getElementById('enq-fields').innerHTML = fields.map(f => `
        <div class="enq-field">
          <span class="enq-key">${f.k}</span>
          <span class="enq-val" style="${f.mono?'font-family:monospace;color:var(--gold);':''}${f.bold?'font-weight:700;font-size:15px;':''}${f.italic?'color:var(--cream-faint);font-style:italic;font-size:12px;':''}">
            ${f.href ? `<a href="${f.href}" target="_blank">${f.v}</a>` : f.v}
          </span>
        </div>
      `).join('');

      document.getElementById('enq-btn-ok').onclick     = () => { closeEnquiry(); updateStatus(b.id, 'confirmed'); };
      document.getElementById('enq-btn-cancel').onclick = () => { closeEnquiry(); updateStatus(b.id, 'cancelled'); };
      document.getElementById('enq-btn-del').onclick    = () => { closeEnquiry(); deleteBooking(b.id); };

      document.getElementById('enquiry-overlay').classList.add('active');
      document.body.style.overflow = 'hidden';
    }
    function closeEnquiry() {
      document.getElementById('enquiry-overlay').classList.remove('active');
      document.body.style.overflow = '';
    }

    // ─── Image Upload ─────────────────────────────────────────
    async function uploadImg(fileInput, urlId, previewId) {
      const file = fileInput.files[0];
      if (!file) return;
      const fd = new FormData();
      fd.append('image', file);
      try {
        showToast('Uploading image…');
        const res = await fetch('/admin/api/upload', { method: 'POST', body: fd });
        if (res.status === 401) { showToast('Session expired. Redirecting…', true); setTimeout(() => location.href='/admin/login', 1500); return; }
        let result;
        try { result = await res.json(); } catch(e) { showToast('Server error.', true); return; }
        if (!res.ok) { showToast(result.message || `Error ${res.status}`, true); return; }
        if (result.success) {
          document.getElementById(urlId).value = result.filePath;
          document.getElementById(previewId).src = result.filePath;
          showToast('Image uploaded!');
        } else { showToast(result.message || 'Upload failed.', true); }
      } catch(e) { showToast('Network error — is the server running?', true); }
    }

    // ─── Save Settings ────────────────────────────────────────
    async function saveSettings(event, section) {
      event.preventDefault();
      const fd = new FormData(event.target);
      let data = {};

      if (section === 'about') {
        data.about = { title: fd.get('about_title'), subtitle: fd.get('about_subtitle'), description1: fd.get('about_description1'), description2: fd.get('about_description2'), image: fd.get('about_image') };
      } else if (section === 'owner') {
        data.owner = { name: fd.get('owner_name'), title: fd.get('owner_title'), subtitle: 'The Owner', designation: fd.get('owner_designation'), philosophy: fd.get('owner_philosophy'), quote: fd.get('owner_quote'), image: fd.get('owner_image') };
      } else if (section === 'packages') {
        data.packages = { subtitle: fd.get('packages_subtitle'), solang: { title: fd.get('pkg_solang_title'), desc: fd.get('pkg_solang_desc') }, spiti: { title: fd.get('pkg_spiti_title'), desc: fd.get('pkg_spiti_desc') }, honeymoon: { title: fd.get('pkg_honeymoon_title'), desc: fd.get('pkg_honeymoon_desc') }, family: { title: fd.get('pkg_family_title'), desc: fd.get('pkg_family_desc') } };
      } else if (section === 'contact') {
        data.global = { siteName: fd.get('global_site_name') };
        data.footer = { phone: fd.get('footer_phone'), whatsapp: fd.get('footer_whatsapp'), email: fd.get('footer_email'), location: fd.get('footer_location'), location_map_url: fd.get('footer_location_map_url') };
      } else if (section === 'catering') {
        const items = [];
        for (let i = 0; i < 5; i++) items.push({ title: fd.get('catering_' + i + '_title') || '', desc: fd.get('catering_' + i + '_desc') || '' });
        data.catering = { items };
      } else if (section === 'equipment') {
        data.equipment = { title: fd.get('equipment_title') || 'WebGL Inspector', tent: { title: fd.get('eq_tent_title') || '', subtitle: fd.get('eq_tent_subtitle') || '', desc: fd.get('eq_tent_desc') || '' }, compass: { title: fd.get('eq_compass_title') || '', subtitle: fd.get('eq_compass_subtitle') || '', desc: fd.get('eq_compass_desc') || '' }, campfire: { title: fd.get('eq_campfire_title') || '', subtitle: fd.get('eq_campfire_subtitle') || '', desc: fd.get('eq_campfire_desc') || '' }, heart: { title: fd.get('eq_heart_title') || '', subtitle: fd.get('eq_heart_subtitle') || '', desc: fd.get('eq_heart_desc') || '' } };
      } else if (section === 'footer') {
        data.footer = { social: { instagram: fd.get('footer_social_instagram'), facebook: fd.get('footer_social_facebook'), youtube: fd.get('footer_social_youtube') } };
      }

      try {
        showLoading('Saving ' + section + '…');
        const res = await fetch('/admin/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        hideLoading();
        if (res.status === 401) { showToast('Session expired. Redirecting…', true); setTimeout(() => location.href='/admin/login', 1500); return; }
        let result;
        try { result = await res.json(); } catch(e) { showToast('Server returned invalid response.', true); return; }
        if (!res.ok) { showToast(result.message || `Server error (${res.status})`, true); return; }
        if (result.success) { showSuccess(section.toUpperCase() + ' Saved!'); showToast(section.toUpperCase() + ' settings saved!'); }
        else { showToast(result.message || 'Failed to save.', true); }
      } catch(e) { hideLoading(); showToast('Network error — is the server running?', true); }
    }

    // ─── CSV Export ───────────────────────────────────────────
    function exportCSV() {
      if (!allBookings.length) { showToast('No enquiries to export.', true); return; }
      const headers = ['ID','Timestamp','Name','Phone','Email','Travelers','Date','Package','Status','Message'];
      const rows = allBookings.map(b => [
        b.id, b.timestamp,
        `"${b.name.replace(/"/g,'""')}"`,
        `"${b.phone}"`,
        `"${b.email}"`,
        b.travelers, b.date, b.package, b.status,
        `"${(b.message||'').replace(/"/g,'""')}"`
      ].join(','));
      const csv = [headers.join(','), ...rows].join('\n');
      const a = document.createElement('a');
      a.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv' }));
      a.download = `soil-enquiries-${new Date().toISOString().split('T')[0]}.csv`;
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
      showToast('Exported to CSV!');
    }
  </script>

</body>
</html>
