<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | <%= settings.global && settings.global.siteName ? settings.global.siteName : 'Soil Village' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    /* ══════════════════════════════════════
       ROOT TOKENS
    ══════════════════════════════════════ */
    :root {
      --gold:       #c5a880;
      --gold-light: #e5c8a0;
      --gold-dim:   rgba(197,168,128,0.12);
      --bg-deep:    #020705;
      --bg-dark:    #050e08;
      --bg-mid:     #0a1610;
      --bg-card:    rgba(6,14,9,0.72);
      --cream:      #f7f4eb;
      --cream-dim:  rgba(247,244,235,0.55);
      --cream-faint:rgba(247,244,235,0.25);
      --emerald:    #0dbb95;
      --border:     rgba(197,168,128,0.1);
      --border-lg:  rgba(197,168,128,0.18);
      --radius:     14px;
      --sidebar-w:  240px;
      --header-h:   68px;
    }

    /* ══════════════════════════════════════
       RESET & BASE
    ══════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--bg-deep);
      color: var(--cream);
      font-family: 'Inter', -apple-system, sans-serif;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ══════════════════════════════════════
       AMBIENT BACKGROUND
    ══════════════════════════════════════ */
    .ambient {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }
    .ambient::before {
      content: '';
      position: absolute;
      top: -20%;
      left: -10%;
      width: 55vw; height: 55vw;
      background: radial-gradient(circle, rgba(13,187,149,0.06) 0%, transparent 65%);
    }
    .ambient::after {
      content: '';
      position: absolute;
      bottom: -10%;
      right: -10%;
      width: 50vw; height: 50vw;
      background: radial-gradient(circle, rgba(197,168,128,0.07) 0%, transparent 65%);
    }

    /* ══════════════════════════════════════
       HEADER
    ══════════════════════════════════════ */
    .header {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--header-h);
      background: rgba(3,8,5,0.92);
      backdrop-filter: blur(24px);
      border-bottom: 1px solid var(--border);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      box-shadow: 0 4px 24px rgba(0,0,0,0.4);
    }

    .header-brand {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .header-logo {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--gold) 0%, #8a6e48 100%);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      box-shadow: 0 0 20px rgba(197,168,128,0.25);
    }
    .header-logo svg { width: 20px; height: 20px; color: #020705; }

    .header-name {
      font-family: 'Cinzel', serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: var(--cream);
    }
    .header-badge {
      font-size: 9px;
      font-family: 'Outfit', sans-serif;
      letter-spacing: 0.22em;
      color: var(--gold);
      font-weight: 700;
      text-transform: uppercase;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .btn-link {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 8px 18px;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      border: 1px solid;
      transition: all 0.25s ease;
      cursor: pointer;
      font-family: 'Outfit', sans-serif;
    }
    .btn-link svg { width: 12px; height: 12px; flex-shrink: 0; }

    .btn-site {
      color: var(--gold);
      border-color: rgba(197,168,128,0.25);
      background: transparent;
    }
    .btn-site:hover {
      border-color: var(--gold);
      background: rgba(197,168,128,0.08);
    }

    .btn-logout {
      color: #fca5a5;
      border-color: rgba(239,68,68,0.25);
      background: rgba(239,68,68,0.05);
    }
    .btn-logout:hover {
      background: rgba(239,68,68,0.15);
      border-color: rgba(239,68,68,0.5);
      color: #fff;
    }

    /* ══════════════════════════════════════
       LAYOUT SHELL
    ══════════════════════════════════════ */
    .shell {
      display: flex;
      min-height: 100vh;
      padding-top: var(--header-h);
      position: relative;
      z-index: 1;
    }

    /* ══════════════════════════════════════
       SIDEBAR
    ══════════════════════════════════════ */
    .sidebar {
      width: var(--sidebar-w);
      min-width: var(--sidebar-w);
      background: rgba(4,10,7,0.8);
      backdrop-filter: blur(20px);
      border-right: 1px solid var(--border);
      padding: 28px 16px;
      position: sticky;
      top: var(--header-h);
      height: calc(100vh - var(--header-h));
      overflow-y: auto;
      flex-shrink: 0;
    }

    .sidebar::-webkit-scrollbar { width: 3px; }
    .sidebar::-webkit-scrollbar-thumb { background: rgba(197,168,128,0.2); border-radius: 4px; }

    .sidebar-label {
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--cream-faint);
      padding: 0 12px;
      margin-bottom: 12px;
      font-family: 'Outfit', sans-serif;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 11px;
      padding: 11px 14px;
      border-radius: 10px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-family: 'Outfit', sans-serif;
      cursor: pointer;
      transition: all 0.22s ease;
      border: none;
      background: transparent;
      color: var(--cream-dim);
      width: 100%;
      text-align: left;
      border-left: 3px solid transparent;
      margin-bottom: 3px;
    }
    .nav-item svg { width: 17px; height: 17px; flex-shrink: 0; opacity: 0.7; }

    .nav-item:hover {
      background: rgba(255,255,255,0.03);
      color: var(--cream);
      border-left-color: rgba(197,168,128,0.3);
    }
    .nav-item.active {
      background: rgba(197,168,128,0.08);
      color: var(--gold);
      border-left-color: var(--gold);
    }
    .nav-item.active svg { opacity: 1; }

    .nav-divider {
      height: 1px;
      background: var(--border);
      margin: 14px 0;
    }

    /* ══════════════════════════════════════
       MAIN CONTENT
    ══════════════════════════════════════ */
    .main {
      flex: 1;
      min-width: 0;
      padding: 32px 36px;
      max-width: calc(100% - var(--sidebar-w));
    }

    /* ══════════════════════════════════════
       TAB PANELS
    ══════════════════════════════════════ */
    .tab-panel {
      display: none;
      flex-direction: column;
      gap: 24px;
    }
    .tab-panel.active {
      display: flex;
      animation: panelIn 0.38s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes panelIn {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ══════════════════════════════════════
       CARDS
    ══════════════════════════════════════ */
    .card {
      background: var(--bg-card);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px 32px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    }

    .card-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      padding-bottom: 20px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      margin-bottom: 24px;
      gap: 16px;
    }

    .card-title {
      font-family: 'Cinzel', serif;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--cream);
    }
    .card-subtitle {
      font-size: 9px;
      font-family: 'Outfit', sans-serif;
      letter-spacing: 0.22em;
      color: var(--gold);
      font-weight: 700;
      text-transform: uppercase;
      margin-top: 4px;
    }

    /* ══════════════════════════════════════
       STATS GRID
    ══════════════════════════════════════ */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .stat-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 22px 24px;
      transition: all 0.3s ease;
    }
    .stat-card:hover {
      transform: translateY(-3px);
      border-color: var(--border-lg);
      box-shadow: 0 12px 30px rgba(0,0,0,0.5);
    }

    .stat-label {
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--cream-faint);
      font-family: 'Outfit', sans-serif;
      margin-bottom: 10px;
      display: block;
    }
    .stat-value {
      font-size: 36px;
      font-weight: 800;
      line-height: 1;
      font-family: 'Outfit', sans-serif;
    }

    .stat-total .stat-value { color: var(--cream); }
    .stat-pending .stat-label { color: rgba(251,191,36,0.7); }
    .stat-pending .stat-value { color: #fbbf24; }
    .stat-confirmed .stat-label { color: rgba(13,187,149,0.7); }
    .stat-confirmed .stat-value { color: var(--emerald); }

    /* ══════════════════════════════════════
       FILTERS & SEARCH
    ══════════════════════════════════════ */
    .filter-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .search-wrap {
      position: relative;
      flex: 1;
      max-width: 300px;
      min-width: 180px;
    }
    .search-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--cream-faint);
      pointer-events: none;
    }
    .search-icon svg { width: 14px; height: 14px; }

    .search-input {
      width: 100%;
      padding: 10px 14px 10px 40px;
      background: rgba(0,0,0,0.2);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      color: var(--cream);
      font-size: 12px;
      font-family: 'Inter', sans-serif;
      outline: none;
      transition: all 0.25s ease;
    }
    .search-input::placeholder { color: var(--cream-faint); }
    .search-input:focus {
      border-color: rgba(197,168,128,0.35);
      background: rgba(197,168,128,0.03);
      box-shadow: 0 0 0 3px rgba(197,168,128,0.07);
    }

    .filter-pills {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .filter-pill {
      padding: 6px 14px;
      border-radius: 100px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-family: 'Outfit', sans-serif;
      cursor: pointer;
      border: 1px solid rgba(255,255,255,0.07);
      background: transparent;
      color: var(--cream-faint);
      transition: all 0.2s ease;
    }
    .filter-pill:hover { border-color: rgba(197,168,128,0.3); color: var(--cream); }
    .filter-pill.active-all   { background: var(--gold); border-color: var(--gold); color: #020705; }
    .filter-pill.active-pending   { background: #fbbf24; border-color: #fbbf24; color: #020705; }
    .filter-pill.active-confirmed { background: var(--emerald); border-color: var(--emerald); color: #020705; }
    .filter-pill.active-cancelled { background: #ef4444; border-color: #ef4444; color: #fff; }

    /* ══════════════════════════════════════
       TABLE
    ══════════════════════════════════════ */
    .table-wrap { overflow-x: auto; }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 620px;
    }
    thead th {
      padding: 10px 14px;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cream-faint);
      font-family: 'Outfit', sans-serif;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      text-align: left;
    }
    thead th:last-child { text-align: right; }

    tbody tr {
      border-bottom: 1px solid rgba(255,255,255,0.03);
      transition: background 0.2s;
    }
    tbody tr:hover { background: rgba(255,255,255,0.015); }
    tbody td { padding: 14px; vertical-align: middle; }
    tbody td:last-child { text-align: right; }

    .booking-id {
      font-family: 'Outfit', sans-serif;
      font-size: 11px;
      font-weight: 700;
      color: var(--gold);
      display: block;
    }
    .booking-date { font-size: 10px; color: var(--cream-faint); display: block; margin-top: 3px; }
    .client-name  { font-size: 13px; font-weight: 700; color: var(--cream); display: block; }
    .client-phone { font-size: 10px; color: var(--cream-dim); display: block; margin-top: 2px; }
    .client-email { font-size: 10px; color: var(--cream-faint); display: block; }

    .pkg-badge {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 6px;
      background: rgba(197,168,128,0.1);
      border: 1px solid rgba(197,168,128,0.2);
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      font-family: 'Outfit', sans-serif;
      margin-bottom: 4px;
    }
    .pkg-meta { font-size: 10px; color: var(--cream-faint); }

    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 6px;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-family: 'Outfit', sans-serif;
      border: 1px solid;
    }
    .status-pending   { background: rgba(251,191,36,0.1);  border-color: rgba(251,191,36,0.3);  color: #fbbf24; }
    .status-confirmed { background: rgba(13,187,149,0.1);  border-color: rgba(13,187,149,0.3);  color: var(--emerald); }
    .status-cancelled { background: rgba(239,68,68,0.1);   border-color: rgba(239,68,68,0.3);   color: #fca5a5; }

    /* ══════════════════════════════════════
       ACTION BUTTONS
    ══════════════════════════════════════ */
    .action-group {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 6px;
      flex-wrap: nowrap;
    }

    .abtn {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 6px 12px;
      border-radius: 8px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-family: 'Outfit', sans-serif;
      cursor: pointer;
      border: 1px solid;
      transition: all 0.22s ease;
      white-space: nowrap;
    }
    .abtn svg { width: 11px; height: 11px; }
    .abtn:active { transform: scale(0.95); }

    .abtn-view {
      background: rgba(197,168,128,0.07); border-color: rgba(197,168,128,0.2); color: var(--gold);
    }
    .abtn-view:hover { background: rgba(197,168,128,0.2); border-color: var(--gold); color: #fff; }

    .abtn-ok {
      background: rgba(13,187,149,0.07); border-color: rgba(13,187,149,0.2); color: #34d399;
    }
    .abtn-ok:hover { background: rgba(13,187,149,0.2); border-color: var(--emerald); color: #fff; }

    .abtn-cancel {
      background: rgba(251,191,36,0.07); border-color: rgba(251,191,36,0.2); color: #fbbf24;
    }
    .abtn-cancel:hover { background: rgba(251,191,36,0.2); border-color: #fbbf24; color: #fff; }

    .abtn-del {
      background: rgba(239,68,68,0.07); border-color: rgba(239,68,68,0.2); color: #fca5a5;
    }
    .abtn-del:hover { background: rgba(239,68,68,0.22); border-color: #ef4444; color: #fff; }

    /* Gold Submit Button */
    .btn-gold {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 28px;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--gold) 0%, #a88760 100%);
      color: #020705;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-family: 'Outfit', sans-serif;
      border: none;
      cursor: pointer;
      transition: all 0.25s ease;
      box-shadow: 0 4px 18px rgba(197,168,128,0.2);
      position: relative;
      overflow: hidden;
    }
    .btn-gold:hover {
      background: linear-gradient(135deg, var(--gold-light) 0%, var(--gold) 100%);
      box-shadow: 0 6px 24px rgba(197,168,128,0.35);
      transform: translateY(-1px);
    }
    .btn-gold:active { transform: scale(0.97); }

    .btn-export {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 18px;
      border-radius: 9px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      color: var(--cream-dim);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-family: 'Outfit', sans-serif;
      cursor: pointer;
      transition: all 0.22s ease;
    }
    .btn-export:hover { border-color: rgba(197,168,128,0.4); background: rgba(197,168,128,0.08); color: var(--cream); }
    .btn-export svg { width: 12px; height: 12px; }

    /* ══════════════════════════════════════
       FORM ELEMENTS
    ══════════════════════════════════════ */
    .form-section { display: flex; flex-direction: column; gap: 20px; }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 2fr; gap: 18px; }

    .field { display: flex; flex-direction: column; gap: 8px; }
    .field label {
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cream-faint);
      font-family: 'Outfit', sans-serif;
    }

    .finput, .ftextarea {
      background: rgba(0,0,0,0.25);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 9px;
      color: var(--cream);
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      padding: 11px 14px;
      outline: none;
      transition: all 0.22s ease;
      width: 100%;
    }
    .ftextarea { resize: vertical; min-height: 80px; }
    .finput:focus, .ftextarea:focus {
      border-color: rgba(197,168,128,0.4);
      background: rgba(197,168,128,0.02);
      box-shadow: 0 0 0 3px rgba(197,168,128,0.07);
    }

    .field-full { grid-column: 1 / -1; }

    .form-footer {
      display: flex;
      justify-content: flex-end;
      padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,0.05);
      margin-top: 4px;
    }

    .divider { height: 1px; background: rgba(255,255,255,0.04); }

    .info-box {
      background: rgba(197,168,128,0.04);
      border: 1px solid rgba(197,168,128,0.12);
      border-radius: 10px;
      padding: 14px 18px;
      font-size: 11px;
      color: var(--cream-dim);
      line-height: 1.6;
    }

    .section-head {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      font-family: 'Outfit', sans-serif;
      margin-bottom: 14px;
    }

    .eq-block {
      background: rgba(0,0,0,0.15);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 20px 22px;
    }
    .eq-block-label {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--cream-faint);
      font-family: 'Outfit', sans-serif;
      margin-bottom: 14px;
    }

    .catering-item {
      background: rgba(0,0,0,0.15);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 18px 20px;
    }

    .item-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px; height: 24px;
      border-radius: 50%;
      background: rgba(197,168,128,0.12);
      border: 1px solid rgba(197,168,128,0.25);
      font-size: 10px;
      font-weight: 800;
      color: var(--gold);
      font-family: 'Outfit', sans-serif;
      flex-shrink: 0;
    }
    .item-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
    }
    .item-header-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--cream-faint);
      font-family: 'Outfit', sans-serif;
    }

    /* Image upload block */
    .img-upload-row {
      display: grid;
      grid-template-columns: 100px 1fr;
      gap: 20px;
      align-items: center;
    }
    .img-preview {
      width: 100px; height: 100px;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.08);
      overflow: hidden;
      background: rgba(0,0,0,0.3);
    }
    .img-preview img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .img-controls { display: flex; flex-direction: column; gap: 10px; }
    .img-input-row { display: flex; gap: 8px; }
    .btn-upload {
      padding: 10px 16px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 9px;
      color: var(--cream-dim);
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Outfit', sans-serif;
      white-space: nowrap;
    }
    .btn-upload:hover { background: rgba(255,255,255,0.1); color: var(--cream); }
    .img-hint { font-size: 10px; color: var(--cream-faint); }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 64px 24px;
      color: var(--cream-faint);
      font-size: 13px;
      font-weight: 300;
    }

    /* ══════════════════════════════════════
       TOAST
    ══════════════════════════════════════ */
    .toast {
      position: fixed;
      bottom: 28px;
      right: 28px;
      padding: 14px 20px;
      border-radius: 12px;
      color: #fff;
      font-size: 13px;
      font-weight: 600;
      z-index: 99999;
      display: flex;
      align-items: center;
      gap: 10px;
      max-width: 340px;
      transform: translateY(20px) scale(0.95);
      opacity: 0;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      pointer-events: none;
      font-family: 'Inter', sans-serif;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    }
    .toast.show { transform: translateY(0) scale(1); opacity: 1; pointer-events: all; }
    .toast-success {
      background: rgba(5,22,15,0.95);
      border: 1px solid rgba(13,187,149,0.5);
    }
    .toast-error {
      background: rgba(22,5,5,0.95);
      border: 1px solid rgba(239,68,68,0.5);
    }
    .toast-icon { font-size: 16px; }

    /* ══════════════════════════════════════
       LOADING OVERLAY
    ══════════════════════════════════════ */
    .loading-overlay {
      position: fixed;
      inset: 0;
      z-index: 99998;
      background: rgba(2,5,3,0.75);
      backdrop-filter: blur(6px);
      display: none;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 18px;
    }
    .loading-overlay.active { display: flex; }

    .spinner {
      width: 44px; height: 44px;
      border: 3px solid rgba(197,168,128,0.15);
      border-top-color: var(--gold);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .spinner-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      font-family: 'Outfit', sans-serif;
      opacity: 0.8;
    }

    /* ══════════════════════════════════════
       SUCCESS OVERLAY
    ══════════════════════════════════════ */
    .success-overlay {
      position: fixed;
      inset: 0;
      z-index: 99997;
      background: rgba(2,5,3,0.7);
      backdrop-filter: blur(6px);
      display: none;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
    }
    .success-overlay.active { display: flex; }

    .check-circle {
      width: 76px; height: 76px;
      border-radius: 50%;
      background: rgba(13,187,149,0.12);
      border: 2px solid var(--emerald);
      display: flex;
      align-items: center;
      justify-content: center;
      animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: 0 0 40px rgba(13,187,149,0.2);
    }
    @keyframes popIn {
      from { transform: scale(0.4); opacity: 0; }
      to   { transform: scale(1); opacity: 1; }
    }
    .check-circle svg {
      width: 36px; height: 36px;
      color: var(--emerald);
      stroke-dasharray: 60;
      stroke-dashoffset: 60;
      animation: drawCheck 0.45s 0.15s ease forwards;
    }
    @keyframes drawCheck { to { stroke-dashoffset: 0; } }

    .check-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--emerald);
      font-family: 'Outfit', sans-serif;
      animation: fadeUp 0.3s 0.3s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ══════════════════════════════════════
       CONFIRM MODAL
    ══════════════════════════════════════ */
    .confirm-overlay {
      position: fixed;
      inset: 0;
      z-index: 99999;
      background: rgba(0,0,0,0.82);
      backdrop-filter: blur(10px);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .confirm-overlay.active { display: flex; }

    .confirm-box {
      background: rgba(8,5,5,0.97);
      border: 1px solid rgba(239,68,68,0.25);
      border-radius: 20px;
      padding: 40px 36px;
      max-width: 400px;
      width: 100%;
      text-align: center;
      position: relative;
      overflow: hidden;
      animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: 0 24px 64px rgba(0,0,0,0.7), 0 0 40px rgba(239,68,68,0.08);
    }
    .confirm-box::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, transparent, #ef4444, transparent);
    }

    .confirm-icon {
      width: 72px; height: 72px;
      border-radius: 50%;
      background: rgba(239,68,68,0.1);
      border: 2px solid rgba(239,68,68,0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px;
      animation: pulseRed 2s infinite;
    }
    @keyframes pulseRed {
      0%,100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.35); }
      50%      { box-shadow: 0 0 0 14px rgba(239,68,68,0); }
    }
    .confirm-icon svg { width: 34px; height: 34px; color: #ef4444; }

    .confirm-title {
      font-size: 17px;
      font-weight: 800;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--cream);
      margin-bottom: 12px;
      font-family: 'Outfit', sans-serif;
    }
    .confirm-msg {
      font-size: 13px;
      color: var(--cream-dim);
      line-height: 1.65;
      margin-bottom: 32px;
    }
    .confirm-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
    .confirm-no  { padding: 13px; border-radius: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--cream-dim); font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; font-family: 'Outfit', sans-serif; cursor: pointer; transition: all 0.2s; }
    .confirm-no:hover { background: rgba(255,255,255,0.1); color: var(--cream); }
    .confirm-yes { padding: 13px; border-radius: 10px; background: rgba(220,38,38,0.2); border: 1px solid rgba(239,68,68,0.4); color: #fca5a5; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; font-family: 'Outfit', sans-serif; cursor: pointer; transition: all 0.2s; }
    .confirm-yes:hover { background: rgba(220,38,38,0.4); border-color: #ef4444; color: #fff; }

    /* ══════════════════════════════════════
       ENQUIRY MODAL
    ══════════════════════════════════════ */
    .enquiry-overlay {
      position: fixed;
      inset: 0;
      z-index: 99990;
      background: rgba(0,0,0,0.78);
      backdrop-filter: blur(8px);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .enquiry-overlay.active { display: flex; }

    .enquiry-box {
      background: rgba(4,10,7,0.99);
      border: 1px solid rgba(197,168,128,0.18);
      border-radius: 20px;
      max-width: 540px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
      animation: slideUp 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 0 32px 80px rgba(0,0,0,0.7), 0 0 40px rgba(197,168,128,0.06);
    }
    @keyframes slideUp {
      from { transform: translateY(30px); opacity: 0; }
      to   { transform: translateY(0); opacity: 1; }
    }
    .enquiry-box::-webkit-scrollbar { width: 4px; }
    .enquiry-box::-webkit-scrollbar-thumb { background: rgba(197,168,128,0.2); border-radius: 4px; }

    .enq-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 28px 18px;
      border-bottom: 1px solid rgba(197,168,128,0.12);
      position: sticky;
      top: 0;
      background: rgba(4,10,7,0.99);
      z-index: 1;
    }
    .enq-label { font-size: 9px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(197,168,128,0.5); margin-bottom: 4px; font-family: 'Outfit', sans-serif; }
    .enq-name  { font-size: 16px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cream); }

    .enq-close {
      width: 34px; height: 34px;
      border-radius: 50%;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      color: var(--cream);
      font-size: 16px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      transition: all 0.2s;
      flex-shrink: 0;
    }
    .enq-close:hover { background: rgba(255,255,255,0.12); }

    .enq-body { padding: 22px 28px 28px; }

    .enq-field {
      display: grid;
      grid-template-columns: 110px 1fr;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .enq-field:last-child { border-bottom: none; }
    .enq-key {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(197,168,128,0.45);
      font-family: 'Outfit', sans-serif;
      padding-top: 3px;
    }
    .enq-val {
      font-size: 13px;
      font-weight: 500;
      color: rgba(247,244,235,0.88);
      line-height: 1.5;
      word-break: break-word;
    }
    .enq-val a { color: var(--gold); text-decoration: underline; }

    .enq-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 22px;
      padding-top: 18px;
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .enq-actions .abtn { flex: 1; min-width: 80px; justify-content: center; padding: 10px; }

    /* ══════════════════════════════════════
       NO-DATA ROWS
    ══════════════════════════════════════ */
    .hidden-row { display: none !important; }

    /* ══════════════════════════════════════
       ROW FADE IN
    ══════════════════════════════════════ */
    #bookings-tbody tr {
      animation: rowIn 0.35s ease both;
    }
    #bookings-tbody tr:nth-child(1)  { animation-delay: 0.04s; }
    #bookings-tbody tr:nth-child(2)  { animation-delay: 0.08s; }
    #bookings-tbody tr:nth-child(3)  { animation-delay: 0.12s; }
    #bookings-tbody tr:nth-child(4)  { animation-delay: 0.16s; }
    #bookings-tbody tr:nth-child(5)  { animation-delay: 0.20s; }
    #bookings-tbody tr:nth-child(n+6){ animation-delay: 0.24s; }
    @keyframes rowIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ══════════════════════════════════════
       SCROLLBAR
    ══════════════════════════════════════ */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: rgba(0,0,0,0.15); }
    ::-webkit-scrollbar-thumb { background: rgba(197,168,128,0.22); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(197,168,128,0.4); }
  </style>
</head>
<body>

  <!-- Ambient BG -->
  <div class="ambient"></div>

  <!-- ══════════════════════════════════════
       HEADER
  ══════════════════════════════════════ -->
  <header class="header">
    <div class="header-brand">
      <div class="header-logo">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 22h20L12 2zm0 3.5L19.5 21h-15L12 5.5z"/></svg>
      </div>
      <div>
        <div class="header-name"><%= (settings.global && settings.global.siteName ? settings.global.siteName : 'SOIL VILLAGE').toUpperCase() %></div>
        <div class="header-badge">Admin Portal</div>
      </div>
    </div>

    <div class="header-actions">
      <a href="/" target="_blank" class="btn-link btn-site">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        View Site
      </a>
      <a href="/admin/logout" class="btn-link btn-logout">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Log Out
      </a>
    </div>
  </header>

  <!-- ══════════════════════════════════════
       LAYOUT SHELL
  ══════════════════════════════════════ -->
  <div class="shell">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-label">Navigation</div>

      <button class="nav-item active" id="nav-bookings" onclick="switchTab('bookings')">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Enquiries
      </button>

      <div class="nav-divider"></div>
      <div class="sidebar-label" style="margin-top:4px;">Content</div>

      <button class="nav-item" id="nav-packages" onclick="switchTab('packages')">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        Packages
      </button>

      <button class="nav-item" id="nav-about" onclick="switchTab('about')">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        About Section
      </button>

      <button class="nav-item" id="nav-owner" onclick="switchTab('owner')">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        Owner Details
      </button>

      <button class="nav-item" id="nav-catering" onclick="switchTab('catering')">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        Catering
      </button>

      <button class="nav-item" id="nav-equipment" onclick="switchTab('equipment')">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Equipment 3D
      </button>

      <div class="nav-divider"></div>
      <div class="sidebar-label" style="margin-top:4px;">Settings</div>

      <button class="nav-item" id="nav-contact" onclick="switchTab('contact')">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Contacts
      </button>

      <button class="nav-item" id="nav-footer" onclick="switchTab('footer')">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
        Social Links
      </button>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="main">

      <!-- ══════════ ENQUIRIES ══════════ -->
      <section id="panel-bookings" class="tab-panel active">

        <!-- Stats -->
        <div class="stats-grid">
          <div class="stat-card stat-total">
            <span class="stat-label">Total Enquiries</span>
            <span class="stat-value" id="stat-total"><%= bookings.length %></span>
          </div>
          <div class="stat-card stat-pending">
            <span class="stat-label">Pending</span>
            <span class="stat-value" id="stat-pending"><%= bookings.filter(b => b.status === 'pending').length %></span>
          </div>
          <div class="stat-card stat-confirmed">
            <span class="stat-label">Confirmed</span>
            <span class="stat-value" id="stat-confirmed"><%= bookings.filter(b => b.status === 'confirmed').length %></span>
          </div>
        </div>

        <!-- Bookings Card -->
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Expedition Enquiries</div>
              <div class="card-subtitle">Real-Time Inbox</div>
            </div>
            <button class="btn-export" onclick="exportCSV()">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              Export CSV
            </button>
          </div>

          <!-- Filter bar -->
          <div class="filter-bar">
            <div class="search-wrap">
              <span class="search-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></span>
              <input type="text" class="search-input" id="search-input" placeholder="Search name, phone, email…" oninput="filterBookings()">
            </div>
            <div class="filter-pills">
              <button class="filter-pill active-all"       id="pill-all"       onclick="setFilter('all')">All</button>
              <button class="filter-pill"                  id="pill-pending"   onclick="setFilter('pending')">Pending</button>
              <button class="filter-pill"                  id="pill-confirmed" onclick="setFilter('confirmed')">Confirmed</button>
              <button class="filter-pill"                  id="pill-cancelled" onclick="setFilter('cancelled')">Cancelled</button>
            </div>
          </div>

          <% if (bookings.length === 0) { %>
            <div class="empty-state">No booking enquiries received yet.</div>
          <% } else { %>
            <div id="no-results-msg" style="display:none;" class="empty-state">No enquiries match your criteria.</div>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>ID / Date</th>
                    <th>Client</th>
                    <th>Package</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="bookings-tbody">
                  <% bookings.forEach(booking => { %>
                    <tr id="row-<%= booking.id %>">
                      <td>
                        <span class="booking-id"><%= booking.id %></span>
                        <span class="booking-date"><%= new Date(booking.timestamp).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></span>
                      </td>
                      <td>
                        <span class="client-name"><%= booking.name %></span>
                        <span class="client-phone"><%= booking.phone %></span>
                        <span class="client-email"><%= booking.email %></span>
                      </td>
                      <td>
                        <span class="pkg-badge"><%= booking.package %></span>
                        <div class="pkg-meta"><%= booking.travelers %> traveler<%= booking.travelers > 1 ? 's' : '' %> · <%= booking.date %></div>
                      </td>
                      <td>
                        <span id="badge-<%= booking.id %>" class="status-badge status-<%= booking.status %>"><%= booking.status %></span>
                      </td>
                      <td>
                        <div class="action-group">
                          <button class="abtn abtn-view" onclick="openEnquiry(<%= JSON.stringify(booking).replace(/</g,'\\u003c').replace(/>/g,'\\u003e').replace(/&/g,'\\u0026') %>)" title="View Details">
