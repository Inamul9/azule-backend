<%- include('partials/header') %>

  <% if (isAdmin) { %>
    <div
      class="admin-banner fixed top-0 left-0 w-full h-[36px] bg-[#0b233a] border-b border-[#0dbb95]/30 flex items-center justify-center text-xs font-semibold text-white tracking-wider z-[999999] select-none shadow-md">
      <span class="mr-2">✎</span> Admin Mode: Hover over text to edit content
      <a href="/admin/dashboard"
        class="ml-4 px-2.5 py-0.5 bg-[#0dbb95] text-black text-[10px] font-bold tracking-widest uppercase rounded hover:bg-[#0c9e7e] transition-all">Dashboard</a>
    </div>

    <style>
      body.admin-mode-active {
        margin-top: 36px !important;
      }

      body.admin-mode-active header {
        top: 36px !important;
      }

      body.admin-mode-active #mobile-menu {
        top: 36px !important;
        height: calc(100% - 36px) !important;
      }
    </style>
    <% } %>

      <!-- CINEMATIC 3D PRELOADER OVERLAY -->
      <div id="preloader"
        class="fixed inset-0 z-[99999] flex flex-col items-center justify-center bg-[#030704] select-none overflow-hidden"
        style="clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);">

        <!-- Vibrant Ambient Orbs Background for Preloader -->
        <div class="absolute inset-0 pointer-events-none z-0">
          <div
            class="absolute top-1/2 left-1/4 w-[500px] h-[500px] bg-[#00f3ff]/20 blur-[150px] rounded-full animate-float-orb -translate-y-1/2"
            style="animation-duration: 12s;"></div>
          <div
            class="absolute top-1/2 right-1/4 w-[500px] h-[500px] bg-[#ff3366]/20 blur-[150px] rounded-full animate-float-orb -translate-y-1/2"
            style="animation-delay: -3s; animation-duration: 15s;"></div>
        </div>

        <div class="relative flex flex-col items-center max-w-lg px-6 text-center">

          <!-- 3D WebGL Preloader Element Canvas -->
          <div class="relative w-60 h-60 md:w-72 md:h-72 flex items-center justify-center">
            <canvas id="preloader-canvas" class="w-full h-full"></canvas>

            <!-- Glowing center mountain wireframe core icon (displays if WebGL takes time to start) -->
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <div
                class="preloader-core-icon w-14 h-14 rounded-full border border-gold/25 flex items-center justify-center bg-forest-dark/40 backdrop-blur-sm animate-pulse-slow">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gold" fill="none" viewBox="0 0 24 24"
                  stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m8 3 4 8 5-5 5 15H2L8 3z" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Cinematic Text Brand Titles -->
          <div class="mt-2 space-y-2">
            <h2
              class="font-cinzel text-4xl md:text-5xl font-extrabold tracking-[0.3em] uppercase preloader-title opacity-0 translate-y-4 drop-shadow-[0_0_20px_rgba(255,215,0,0.5)] bg-clip-text text-transparent bg-gradient-to-r from-[#00f3ff] via-[#ff3366] to-gold animate-gradient-text">
              SOIL VILLAGE
            </h2>
            <p
              class="font-sans text-xs tracking-[0.5em] text-[#00f3ff] uppercase preloader-subtitle opacity-0 translate-y-4 font-bold drop-shadow-[0_0_8px_rgba(0,243,255,0.8)]">
              STAY. EXPLORE. CONNECT.
            </p>
          </div>

          <!-- Interactive Quote Panel -->
          <div
            class="mt-8 max-w-sm px-6 py-3.5 glass-panel rounded border border-gold/15 bg-forest-deep/40 preloader-quote opacity-0 scale-95 transition-all duration-500">
            <span
              class="text-[9px] font-sans tracking-[0.25em] text-gold/80 block uppercase mb-1 whitespace-nowrap">Wilderness
              Gaze</span>
            <p class="text-[11px] font-sans font-light italic text-cream/70 leading-relaxed">
              "Leave nothing but footprints, take nothing but memories."
            </p>
          </div>

          <!-- Progress Indicator -->
          <div
            class="mt-10 flex flex-col items-center w-48 space-y-2 preloader-progress-container opacity-0 translate-y-4">
            <div class="text-[10px] font-mono tracking-widest text-gold/90 flex items-center space-x-1.5">
              <span class="animate-pulse">●</span>
              <span id="preloader-percent">00</span>
              <span>% LOADED</span>
            </div>
            <!-- Progress Bar Track -->
            <div class="w-full h-[2px] bg-cream/10 rounded overflow-hidden relative">
              <div id="preloader-progress-bar"
                class="absolute top-0 left-0 h-full w-0 bg-gradient-to-r from-[#00f3ff] via-[#ff3366] to-gold shadow-[0_0_20px_rgba(255,51,102,0.8)] transition-all duration-300">
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- 1. HERO SECTION -->
      <section id="hero"
        class="relative w-full min-h-screen flex items-center justify-center overflow-hidden z-10 py-20">

        <!-- Fullscreen Zoomable Solang Valley Mountain Background -->
        <div class="absolute top-0 left-0 w-full h-full z-0 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-forest-deep/20 via-forest-deep/60 to-forest-deep z-10">
          </div>
          <img src="/assets/hero_bg.png" alt="Solang Valley Mountains, Manali"
            class="w-full h-full object-cover scale-100 origin-center hero-bg-zoom">
        </div>

        <!-- Parallax Fog Layer 1 -->
        <div class="absolute bottom-0 left-0 w-full h-1/2 pointer-events-none z-10 opacity-30 select-none hero-fog-1">
          <svg viewBox="0 0 1440 320" class="w-full h-full" preserveAspectRatio="none">
            <path fill="#07160c"
              d="M0,224L120,202.7C240,181,480,139,720,138.7C960,139,1200,181,1320,202.7L1440,224L1440,320L1320,320C1200,320,960,320,720,320C480,320,240,320,120,320L0,320Z">
            </path>
          </svg>
        </div>

        <!-- Parallax Fog Layer 2 -->
        <div class="absolute bottom-0 right-0 w-full h-2/3 pointer-events-none z-10 opacity-20 select-none hero-fog-2">
          <svg viewBox="0 0 1440 320" class="w-full h-full transform scale-x-[-1]" preserveAspectRatio="none">
            <path fill="#1b4332"
              d="M0,192L120,176C240,160,480,128,720,138.7C960,149,1200,203,1320,229.3L1440,256L1440,320L1320,320C1200,320,960,320,720,320C480,320,240,320,120,320L0,320Z">
            </path>
          </svg>
        </div>

        <!-- Campfire Radial Ambient Light Glow overlay -->
        <div
          class="absolute bottom-[-10%] left-1/2 -translate-x-1/2 w-[80%] max-w-[800px] h-[350px] pointer-events-none z-10 campfire-glow-radial rounded-full">
        </div>

        <!-- Starry Sky backdrop for Hero Section -->
        <div class="stars-container absolute top-0 left-0 w-full h-full pointer-events-none z-1"></div>

        <!-- Hero Content Panel -->
        <div class="max-w-4xl mx-auto px-6 text-center relative z-20 hero-text-container mt-12 md:mt-6">

          <!-- Vintage Mountain Badge Logo -->
          <div class="flex justify-center mb-6">
            <div
              class="hero-logo-img glass-panel-gold rounded-full p-4 md:p-6 border border-gold/30 shadow-gold-glow bg-forest-dark/50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 md:h-16 md:w-16 text-gold" viewBox="0 0 100 100"
                fill="none">
                <!-- Mountain outline -->
                <path d="M50 15L85 75H15L50 15Z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" />
                <path d="M50 15V75M32 50L50 35L68 50" stroke="currentColor" stroke-width="2" />
                <!-- Cozy Tent inside logo -->
                <path d="M42 75L50 60L58 75H42Z" fill="currentColor" opacity="0.3" />
                <circle cx="50" cy="40" r="1.5" fill="currentColor" />
                <!-- Rising birds -->
                <path d="M62 28C64 27 65 29 67 28M28 32C30 31 31 33 33 32" stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round" />
              </svg>
            </div>
          </div>

          <!-- Stay. Explore. Connect. Badge -->
          <div class="hero-subtitle mb-4">
            <span
              class="text-xs md:text-sm font-sans font-semibold tracking-[0.4em] text-gold uppercase bg-gold/10 border border-gold/20 px-4 py-1.5 rounded-full inline-block">
              Stay. Explore. Connect.
            </span>
          </div>

          <!-- Main Heading -->
          <h1
            class="hero-title-main font-cinzel text-5xl md:text-8xl font-black tracking-widest leading-tight text-transparent bg-clip-text bg-gradient-to-b from-cream-light via-cream to-gold/90 drop-shadow-[0_6px_20px_rgba(0,0,0,0.8)] select-none">
            SOIL VILLAGE
          </h1>

          <!-- Subheading Details -->
          <div
            class="hero-badge-tag flex flex-col md:flex-row items-center justify-center space-y-2 md:space-y-0 md:space-x-6 mt-2 mb-6">
            <span
              class="font-cinzel text-lg md:text-2xl tracking-[0.2em] font-medium text-gold-light uppercase drop-shadow-[0_2px_4px_rgba(0,0,0,0.4)]">
              SOIL VALLEY – MANALI
            </span>
            <span class="hidden md:inline text-gold/50">•</span>
            <span
              class="font-sans text-xs md:text-sm font-bold tracking-[0.25em] text-cream uppercase bg-forest-medium/50 px-4 py-1 rounded border border-cream/10">
              1 NIGHTS / 2 DAYS
            </span>
            <span class="hidden md:inline text-gold/50">•</span>
            <span
              class="font-sans text-xs md:text-sm font-bold tracking-[0.25em] text-gold uppercase bg-forest-medium/50 px-4 py-1 rounded border border-gold/10">
              Pickup Delhi
            </span>
          </div>

          <!-- Short Intro Text -->
          <p
            class="hero-info-p text-sm md:text-base font-sans font-light text-cream/80 max-w-xl mx-auto leading-relaxed mb-10 drop-shadow">
            Escape to an exclusive wilderness glamping retreat hidden within Solang Valley. Experience cozy log fire
            bonfires, pristine alpine river streams, majestic peak trails, and premium stargazing comforts.
          </p>

          <!-- Call to Actions -->
          <div
            class="hero-ctas flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-6">
            <a href="#book"
              class="w-full sm:w-auto text-center px-8 py-4 bg-gold hover:bg-gold-glow text-forest-deep font-sans font-bold text-xs tracking-widest uppercase rounded shadow-lg shadow-gold/20 hover:shadow-gold-glow transform hover:-translate-y-0.5 transition-all duration-300">
              Book Now
            </a>
            <a href="#itinerary"
              class="w-full sm:w-auto text-center px-8 py-4 glass-panel hover:bg-cream/10 text-cream border border-gold/30 hover:border-gold font-sans font-semibold text-xs tracking-widest uppercase rounded shadow-glass transform hover:-translate-y-0.5 transition-all duration-300">
              Explore Itinerary
            </a>
          </div>

        </div>

        <!-- Scroll Down indicator mouse -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 hidden md:block">
          <a href="#itinerary"
            class="flex flex-col items-center text-cream/40 hover:text-gold transition-colors duration-300">
            <span class="text-[9px] font-sans tracking-widest mb-2 uppercase">Scroll to Discover</span>
            <div class="w-[20px] h-[36px] border border-cream/30 rounded-full flex justify-center py-2">
              <div class="w-[3px] h-[6px] bg-gold rounded-full animate-bounce"></div>
            </div>
          </a>
        </div>

      </section>

      <!-- 2. CAMPING ITINERARY SECTION -->
      <section id="itinerary" class="relative py-24 bg-[#070e08] border-t border-b border-gold/10">

        <!-- Night starry ambiance -->
        <div class="stars-container absolute top-0 left-0 w-full h-full pointer-events-none opacity-30"></div>

        <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">

          <!-- Section Title -->
          <div class="text-center mb-16 section-header-reveal">
            <span
              class="text-xs font-sans font-bold tracking-[0.3em] text-gold uppercase block mb-3 <%= isAdmin ? 'editable-text' : '' %>"
              data-edit-key="itinerary.subtitle">
              <%= settings.itinerary ? settings.itinerary.subtitle : 'Chronological Track' %>
            </span>
            <h2 id="itinerary-section-title"
              class="font-cinzel text-3xl md:text-5xl font-extrabold tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-cream-light via-cream to-gold-light uppercase transition-all duration-300 drop-shadow-[0_2px_8px_rgba(0,0,0,0.5)] <%= isAdmin ? 'editable-text' : '' %>"
              data-edit-key="itinerary.title">
              <%= settings.itinerary ? settings.itinerary.title : 'CAMPING ITINERARY' %>
            </h2>
            <span id="itinerary-section-subtitle"
              class="text-sm font-serif italic text-gold mt-2 block tracking-widest transition-all duration-300 <%= isAdmin ? 'editable-text' : '' %>"
              data-edit-key="itinerary.sub_title_2">
              <%= settings.itinerary ? settings.itinerary.sub_title_2 : 'SOLANG VALLEY RETREAT' %>
            </span>
            <div class="w-16 h-[2px] bg-gold mx-auto mt-6"></div>
          </div>

          <!-- Dual Itinerary timeline grid (Solang Valley vs Spiti Valley) -->
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

            <!-- ITINERARY TIMELINE COLUMN (Left 7 Cols) -->
            <div class="lg:col-span-7 relative">

              <!-- ==================== SOLANG TIMELINE (1N/2D) ==================== -->
              <div id="itinerary-timeline-solang"
                class="relative border-l border-gold/25 pl-6 md:pl-10 space-y-16 transition-all duration-500">

                <!-- Day 1 Segment -->
                <div class="relative">
                  <div
                    class="absolute -left-[43px] md:-left-[59px] top-0 w-8 h-8 md:w-9 md:h-9 bg-gold rounded-full flex items-center justify-center text-forest-deep font-cinzel font-bold text-sm md:text-base border border-gold shadow-gold-glow">
                    01</div>
                  <h3
                    class="font-cinzel text-xl md:text-3xl font-extrabold tracking-widest text-gold uppercase mb-8 <%= isAdmin ? 'editable-text' : '' %>"
                    data-edit-key="itinerary.days.0.title">
                    <%= settings.itinerary ? settings.itinerary.days[0].title : 'DAY 1: BASE CAMP SETTLE' %>
                  </h3>

                  <div class="space-y-8">
                    <!-- Item 1 -->
                    <div class="timeline-item flex items-start space-x-4 group">
                      <div
                        class="w-8 h-8 rounded-full bg-forest-medium/70 border border-gold/20 flex items-center justify-center text-gold text-xs font-mono shrink-0 mt-0.5 group-hover:bg-gold group-hover:text-forest-deep transition-all duration-300 z-10 shadow-md">
                        01</div>
                      <div
                        class="timeline-content glass-panel p-5 rounded border border-gold/10 hover:border-gold/30 hover:scale-[1.02] hover:shadow-glass-gold bg-forest-deep/30 hover:bg-forest-deep/60 w-full transition-all duration-300">
                        <div class="flex flex-wrap justify-between items-center mb-2 gap-2">
                          <h4
                            class="font-cinzel text-xs font-semibold tracking-wider text-gold uppercase mb-1 <%= isAdmin ? 'editable-text' : '' %>"
                            data-edit-key="itinerary.days.0.items.0.title">
                            <%= settings.itinerary ? settings.itinerary.days[0].items[0].title : 'MEET & GREET' %>
                          </h4>
                          <span
                            class="text-[9px] font-mono text-cream/50 bg-forest-dark px-2 py-0.5 rounded border border-cream/5 <%= isAdmin ? 'editable-text' : '' %>"
                            data-edit-key="itinerary.days.0.items.0.meta">
                            <%= settings.itinerary ? settings.itinerary.days[0].items[0].meta : '10:00 AM • El: 2,050m'
                              %>
                          </span>
                        </div>
                        <p class="text-sm font-sans font-light text-cream/90 <%= isAdmin ? 'editable-text' : '' %>"
                          data-edit-key="itinerary.days.0.items.0.desc">
                          <%= settings.itinerary ? settings.itinerary.days[0].items[0].desc
                            : 'Meet and greet at Renush sh Homestay, Soyal. Assembly briefing and guide allocation.' %>
                        </p>
                      </div>
                    </div>
                    <!-- Item 2 -->
                    <div class="timeline-item flex items-start space-x-4 group">
                      <div
                        class="w-8 h-8 rounded-full bg-forest-medium/70 border border-gold/20 flex items-center justify-center text-gold text-xs font-mono shrink-0 mt-0.5 group-hover:bg-gold group-hover:text-forest-deep transition-all duration-300 z-10 shadow-md">
                        02</div>
                      <div
                        class="timeline-content glass-panel p-5 rounded border border-gold/10 hover:border-gold/30 hover:scale-[1.02] hover:shadow-glass-gold bg-forest-deep/30 hover:bg-forest-deep/60 w-full transition-all duration-300">
                        <div class="flex flex-wrap justify-between items-center mb-2 gap-2">
                          <h4
                            class="font-cinzel text-xs font-semibold tracking-wider text-gold uppercase mb-1 <%= isAdmin ? 'editable-text' : '' %>"
                            data-edit-key="itinerary.days.0.items.1.title">
                            <%= settings.itinerary ? settings.itinerary.days[0].items[1].title : '2 HOUR ALPINE TREK' %>
                          </h4>
                          <span
                            class="text-[9px] font-mono text-cream/50 bg-forest-dark px-2 py-0.5 rounded border border-cream/5 <%= isAdmin ? 'editable-text' : '' %>"
                            data-edit-key="itinerary.days.0.items.1.meta">
                            <%= settings.itinerary ? settings.itinerary.days[0].items[1].meta : '11:30 AM • El: 2,300m'
                              %>
                          </span>
                        </div>
                        <p class="text-sm font-sans font-light text-cream/90 <%= isAdmin ? 'editable-text' : '' %>"
                          data-edit-key="itinerary.days.0.items.1.desc">
                          <%= settings.itinerary ? settings.itinerary.days[0].items[1].desc
                            : 'After that we proceed for a scenic 2 hour trek up the valley ridges passing pristine pine boundaries.'
                            %>
                        </p>
                      </div>
                    </div>
                    <!-- Item 3 -->
                    <div class="timeline-item flex items-start space-x-4 group">
                      <div
                        class="w-8 h-8 rounded-full bg-forest-medium/70 border border-gold/20 flex items-center justify-center text-gold text-xs font-mono shrink-0 mt-0.5 group-hover:bg-gold group-hover:text-forest-deep transition-all duration-300 z-10 shadow-md">
                        03</div>
                      <div
                        class="timeline-content glass-panel p-5 rounded border border-gold/10 hover:border-gold/30 hover:scale-[1.02] hover:shadow-glass-gold bg-forest-deep/30 hover:bg-forest-deep/60 w-full transition-all duration-300">
                        <div class="flex flex-wrap justify-between items-center mb-2 gap-2">
                          <h4
                            class="font-cinzel text-xs font-semibold tracking-wider text-gold uppercase mb-1 <%= isAdmin ? 'editable-text' : '' %>"
                            data-edit-key="itinerary.days.0.items.2.title">
                            <%= settings.itinerary ? settings.itinerary.days[0].items[2].title : 'REACH CAMP & LUNCH' %>
                          </h4>
                          <span
                            class="text-[9px] font-mono text-cream/50 bg-forest-dark px-2 py-0.5 rounded border border-cream/5 <%= isAdmin ? 'editable-text' : '' %>"
                            data-edit-key="itinerary.days.0.items.2.meta">
                            <%= settings.itinerary ? settings.itinerary.days[0].items[2].meta : '01:30 PM • El: 2,480m'
                              %>
                          </span>
                        </div>
                        <p class="text-sm font-sans font-light text-cream/90 <%= isAdmin ? 'editable-text' : '' %>"
                          data-edit-key="itinerary.days.0.items.2.desc">
                          <%= settings.itinerary ? settings.itinerary.days[0].items[2].desc
                            : 'Reach at camp, settle in premium glamping tents, and enjoy a hot wholesome mountain lunch.'
                            %>
                        </p>
                      </div>
                    </div>
                    <!-- Item 4 -->
                    <div class="timeline-item flex items-start space-x-4 group">
                      <div
                        class="w-8 h-8 rounded-full bg-forest-medium/70 border border-gold/20 flex items-center justify-center text-gold text-xs font-mono shrink-0 mt-0.5 group-hover:bg-gold group-hover:text-forest-deep transition-all duration-300 z-10 shadow-md">
                        04</div>
                      <div
                        class="timeline-content glass-panel p-5 rounded border border-gold/10 hover:border-gold/30 hover:scale-[1.02] hover:shadow-glass-gold bg-forest-deep/30 hover:bg-forest-deep/60 w-full transition-all duration-300">
                        <div class="flex flex-wrap justify-between items-center mb-2 gap-2">
                          <h4
                            class="font-cinzel text-xs font-semibold tracking-wider text-gold uppercase mb-1 <%= isAdmin ? 'editable-text' : '' %>"
                            data-edit-key="itinerary.days.0.items.3.title">
                            <%= settings.itinerary ? settings.itinerary.days[0].items[3].title : 'RELAX & EVENING TEA'
                              %>
                          </h4>
                          <span
                            class="text-[9px] font-mono text-cream/50 bg-forest-dark px-2 py-0.5 rounded border border-cream/5 <%= isAdmin ? 'editable-text' : '' %>"
                            data-edit-key="itinerary.days.0.items.3.meta">
                            <%= settings.itinerary ? settings.itinerary.days[0].items[3].meta : '04:30 PM • El: 2,480m'
                              %>
                          </span>
                        </div>
                        <p class="text-sm font-sans font-light text-cream/90 <%= isAdmin ? 'editable-text' : '' %>"
                          data-edit-key="itinerary.days.0.items.3.desc">
                          <%= settings.itinerary ? settings.itinerary.days[0].items[3].desc
                            : 'After lunch, relax in the serene environment. Fresh herbal sunset tea served directly next to the river banks.'
                            %>
                        </p>
                      </div>
                    </div>
                    <!-- Item 5 -->
                    <div class="timeline-item flex items-start space-x-4 group">
                      <div
                        class="w-8 h-8 rounded-full bg-forest-medium/70 border border-gold/20 flex items-center justify-center text-gold text-xs font-mono shrink-0 mt-0.5 group-hover:bg-gold group-hover:text-forest-deep transition-all duration-300 z-10 shadow-md">
                        05</div>
                      <div
                        class="timeline-content glass-panel p-5 rounded border border-gold/10 hover:border-gold/30 hover:scale-[1.02] hover:shadow-glass-gold bg-forest-deep/30 hover:bg-forest-deep/60 w-full transition-all duration-300">
                        <div class="flex flex-wrap justify-between items-center mb-2 gap-2">
                          <h4
                            class="font-cinzel text-xs font-semibold tracking-wider text-gold uppercase mb-1 <%= isAdmin ? 'editable-text' : '' %>"
                            data-edit-key="itinerary.days.0.items.4.title">
                            <%= settings.itinerary ? settings.itinerary.days[0].items[4].title : 'SNACKS & EXPLORATION'
                              %>
                          </h4>
                          <span
                            class="text-[9px] font-mono text-cream/50 bg-forest-dark px-2 py-0.5 rounded border border-cream/5 <%= isAdmin ? 'editable-text' : '' %>"
                            data-edit-key="itinerary.days.0.items.4.meta">
                            <%= settings.itinerary ? settings.itinerary.days[0].items[4].meta : '06:30 PM • El: 2,520m'
                              %>
                          </span>
                        </div>
                        <p class="text-sm font-sans font-light text-cream/90 <%= isAdmin ? 'editable-text' : '' %>"
                          data-edit-key="itinerary.days.0.items.4.desc">
                          <%= settings.itinerary ? settings.itinerary.days[0].items[4].desc
                            : 'Delicious warm starters served. Embark on a brief pine trail walk under rising twilight skies.'
                            %>
                        </p>
                      </div>
                    </div>
                    <!-- Item 6 -->
