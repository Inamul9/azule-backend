        </div>

        <style>
          /* Styling for Admin Mode elements */
          .editable-text {
            position: relative !important;
            transition: outline 0.25s ease, box-shadow 0.25s ease;
          }

          .editable-text:hover {
            outline: 1px dashed #0dbb95 !important;
            box-shadow: 0 0 12px rgba(13, 187, 149, 0.25);
            cursor: pointer;
          }

          .edit-pencil-btn {
            position: absolute;
            top: -12px;
            right: -12px;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background-color: #0dbb95;
            border: 1px solid #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            cursor: pointer;
            font-size: 11px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
            z-index: 999999;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease, transform 0.25s ease;
            transform: scale(0.8);
          }

          .editable-text:hover .edit-pencil-btn {
            opacity: 1;
            pointer-events: auto;
            transform: scale(1);
          }

          .edit-pencil-btn:hover {
            transform: scale(1.15) !important;
            background-color: #0c9e7e;
          }

          /* Modal glass panel styling fallback */
          .glass-panel {
            background: rgba(5, 14, 9, 0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
          }
        </style>

        <script>
          // Initialize editable elements by injecting the hover pencil buttons
          window.addEventListener('DOMContentLoaded', () => {
            // Add admin body class to trigger margin offset
            document.body.classList.add('admin-mode-active');

            const editableElements = document.querySelectorAll('.editable-text');
            editableElements.forEach(el => {
              // Ensure relative positioning
              el.style.position = 'relative';

              // Create pencil button
              const btn = document.createElement('button');
              btn.type = 'button';
              btn.className = 'edit-pencil-btn';
              btn.innerHTML = '✎';
              btn.title = 'Edit this content';

              // Avoid nested event trigger issues
              btn.addEventListener('click', (e) => {
                e.stopPropagation();
                e.preventDefault();
                openInlineModal(el);
              });

              // Click element itself to edit
              el.addEventListener('click', (e) => {
                // If clicked link or button inside, let it proceed unless it's the edit action
                if (e.target.tagName !== 'A' && e.target.tagName !== 'BUTTON') {
                  e.preventDefault();
                  e.stopPropagation();
                  openInlineModal(el);
                }
              });

              el.appendChild(btn);
            });
          });

          function openInlineModal(element) {
            const key = element.getAttribute('data-edit-key');
            if (!key) return;

            const modal = document.getElementById('inline-edit-modal');
            const keyInput = document.getElementById('inline-edit-key');
            const label = document.getElementById('inline-edit-label');
            const container = document.getElementById('inline-editor-container');

            // Set key
            keyInput.value = key;
            label.innerText = `Edit Field [${key.replace('.', ' > ').toUpperCase()}]`;

            // Get current content (clone text, excluding the pencil button)
            const clone = element.cloneNode(true);
            const pencil = clone.querySelector('.edit-pencil-btn');
            if (pencil) pencil.remove();

            // Clean up text
            const currentText = clone.innerText.trim();

            // Determine field type (long paragraphs get textareas, titles get text inputs)
            const isLongText = currentText.length > 80 || key.includes('description') || key.includes('quote');

            container.innerHTML = '';
            if (isLongText) {
              const textarea = document.createElement('textarea');
              textarea.name = 'value';
              textarea.rows = 6;
              textarea.className = 'input-field w-full px-4 py-3 rounded text-sm bg-white/5 border border-white/10 text-white outline-none focus:border-gold';
              textarea.value = currentText;
              container.appendChild(textarea);
            } else {
              const input = document.createElement('input');
              input.type = 'text';
              input.name = 'value';
              input.className = 'input-field w-full px-4 py-3 rounded text-sm bg-white/5 border border-white/10 text-white outline-none focus:border-gold';
              input.value = currentText;
              container.appendChild(input);
            }

            // Display Modal
            modal.classList.remove('hidden');
          }

          function closeInlineModal() {
            document.getElementById('inline-edit-modal').classList.add('hidden');
          }

          async function saveInlineContent(event) {
            event.preventDefault();

            const form = event.target;
            const key = form.querySelector('#inline-edit-key').value;
            const value = form.querySelector('[name="value"]').value;

            // Build deeply nested payload from dot-notation key
            // e.g. "itinerary.days.0.items.2.title" => correct nested object/array structure
            function buildNestedPayload(keysArr, val) {
              if (keysArr.length === 0) return val;
              const k = keysArr[0];
              const rest = keysArr.slice(1);
              const isIndex = /^\d+$/.test(k);
              if (isIndex) {
                const arr = [];
                arr[parseInt(k)] = buildNestedPayload(rest, val);
                return arr;
              } else {
                const obj = {};
                obj[k] = buildNestedPayload(rest, val);
                return obj;
              }
            }

            const payload = buildNestedPayload(key.split('.'), value);

            try {
              const response = await fetch('/admin/api/settings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });

              const result = await response.json();
              if (result.success) {
                // Update window.WEBSITE_SETTINGS in-memory
                if (window.WEBSITE_SETTINGS) {
                  let current = window.WEBSITE_SETTINGS;
                  const parts = key.split('.');
                  for (let i = 0; i < parts.length - 1; i++) {
                    const part = parts[i];
                    const nextPart = parts[i + 1];
                    const isNextIndex = /^\d+$/.test(nextPart);
                    if (current[part] === undefined) {
                      current[part] = isNextIndex ? [] : {};
                    }
                    current = current[part];
                  }
                  current[parts[parts.length - 1]] = value;
                }

                // Update DOM element directly without full page reload
                const element = document.querySelector(`[data-edit-key="${key}"]`);
                if (element) {
                  const pencil = element.querySelector('.edit-pencil-btn');
                  if (key.endsWith('.title') && key.startsWith('packages.') && typeof window.formatTitleWithGradient === 'function') {
                    element.innerHTML = window.formatTitleWithGradient(value);
                  } else {
                    element.innerText = value;
                  }
                  if (pencil) element.appendChild(pencil);
                }
                closeInlineModal();
              } else {
                alert('Failed to save content: ' + (result.message || 'Unknown error'));
              }
            } catch (err) {
              console.error(err);
              alert('Error saving content to server.');
            }
          }
        </script>
        <% } %>

          <script>
            window.WEBSITE_SETTINGS = <% - JSON.stringify(settings) %>;
          </script>

          <script>
            window.equipmentSettings = <% - JSON.stringify(settings.equipment || {}) %>;
          </script>

          <%- include('partials/footer') %>