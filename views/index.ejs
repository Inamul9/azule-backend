            <h3 class="font-cinzel text-md font-bold tracking-widest text-gold mb-6 uppercase flex items-center gap-2">
              <span>✎</span> Edit Website Content
            </h3>

            <form id="inline-edit-form" onsubmit="saveInlineContent(event)" class="space-y-5">
              <input type="hidden" id="inline-edit-key" name="key">

              <div class="flex flex-col space-y-2">
                <label id="inline-edit-label"
                  class="text-[10px] font-sans font-bold tracking-widest text-[#fcfaf2]/50 uppercase">Field
                  Content</label>
